    "# Activity "
   ]
  },
  {
   "cell_type": "code",
   "execution_count": 61,
   "id": "c4262060-22b3-4c51-b92f-e793f76d227f",
   "metadata": {},
   "outputs": [],
   "source": [
    "df['activity'] = (df['activity'].str.lower().str.strip().str.replace(r'[^a-z\\s]', '', regex=True))"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": 62,
   "id": "ef06b0aa-a3c6-4de0-8bd5-3e62b2a5869b",
   "metadata": {},
   "outputs": [],
   "source": [
    "def categorize_activity(x):\n",
    "    if pd.isna(x):\n",
    "        return 'other'\n",
    "    \n",
    "    if 'surf' in x:\n",
    "        return 'surfing'\n",
    "    elif 'swim' in x or 'bathing' in x:\n",
    "        return 'swimming'\n",
    "    elif 'dive' in x or 'snorkel' in x:\n",
    "        return 'diving/snorkeling'\n",
    "    elif 'fish' in x:\n",
    "        return 'fishing'\n",
    "    elif 'boat' in x or 'kayak' in x or 'canoe' in x:\n",
    "        return 'boating'\n",
    "    elif 'wade' in x:\n",
    "        return 'wading'\n",
    "    elif 'stand' in x or 'paddle' in x:\n",
    "        return 'paddleboarding'\n",
    "    else:\n",
    "        return 'other'"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": 63,
   "id": "50b466d3-bebb-4090-97ad-cfadcb527d01",
   "metadata": {},
   "outputs": [],
   "source": [
    "df['activity'] = df['activity'].apply(categorize_activity)"
   ]
  },
